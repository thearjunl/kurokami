# KUROKAMI Environment Configuration
# Copy this file to .env and customize for your environment

# Environment (development, staging, production)
KUROKAMI_ENV=development

# Database Configuration
DATABASE_URL=sqlite:///data/kurokami.db
# For PostgreSQL in production:
# DATABASE_URL=postgresql://user:password@localhost:5432/kurokami

# AI/LLM Configuration
OLLAMA_HOST=http://127.0.0.1:11434
DEFAULT_MODEL=qwen2.5:14b
FALLBACK_MODEL=dolphin-mistral

# Security Settings
ALLOW_EXPLOITS=false
WORKSPACE_ENCRYPTION=false
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=your-base64-encoded-key-here

# API Authentication (if enabled)
# API_KEY=your-secret-api-key-here
# JWT_SECRET=your-jwt-secret-here

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=data/logs

# Rate Limiting
RATE_LIMIT_ENABLED=true
MAX_SCANS_PER_HOUR=10
MAX_CONCURRENT_SCANS=3

# Timeouts (in seconds)
MODULE_TIMEOUT=300
SCAN_TIMEOUT=3600

# Export Configuration
EXPORTS_DIR=data/exports
VECTOR_STORE_DIR=data/vector_store

# Monitoring & Metrics
ENABLE_METRICS=false
METRICS_PORT=9090

# Email Notifications (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# NOTIFICATION_EMAIL=admin@example.com
